{
  "manifest_version": 3,
  "name": "Agent Tab Bridge",
  "version": "0.1.0",
  "description": "让本地 AI agent 并行、后台、互不干扰地控制各自的彩色标签组",
  "minimum_chrome_version": "116",
  "permissions": ["tabs", "tabGroups", "scripting", "debugger", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_title": "Agent Tab Bridge",
    "default_popup": "popup/popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src 'self' ws://127.0.0.1:* ws://localhost:*;"
  }
}
